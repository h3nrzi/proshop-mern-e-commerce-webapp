{
    "collection": "@nestjs/schematics",
    "sourceRoot": "server/src",
    "compilerOptions": {
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true,
                    "dtoFileNameSuffix": [
                        ".dto.ts",
                        ".entity.ts"
                    ]
                }
            }
        ]
    }
}